# ============================================================
#  三个 API 渠道选一个填就行，不用全填
#  新手推荐 OpenRouter —— 注册即用，不需要国际信用卡
# ============================================================

# --- 方案一：OpenRouter（推荐新手）---
# 注册地址：https://openrouter.ai/keys
# 一个 key 可以调 GPT-4o、Claude、Gemini 等几百个模型
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=memoria-chat

# --- 方案二：OpenAI 官方 ---
# 注册地址：https://platform.openai.com/api-keys
# 需要国际信用卡
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- 方案三：火山引擎（国内直连）---
# 注册地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 支持 GLM、Kimi 等国产模型
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ============================================================
#  以下是可选配置，不懂就别动
# ============================================================

# 鉴权 token（本机 npm start 可不填，远程访问或 Docker 部署时必须取消注释并设置）
# ADMIN_TOKEN=your-secret-token

# 监听地址
HOST=127.0.0.1
PORT=3000

# 默认模型
MODEL=gpt-4o

# 联网搜索（Serper.dev，免费 2500 次 Google 搜索）
# 注册地址：https://serper.dev
# SERPER_API_KEY=

# 自定义 TTS（如 Kokoro-FastAPI，docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:v0.1.4）
# 设了就走自定义 TTS，不设就走 OpenAI TTS API 或 Edge TTS
# TTS_BASE_URL=http://127.0.0.1:8880/v1
# TTS_API_KEY=not-needed

# 自定义 STT（支持任何 OpenAI 兼容的 STT 服务）
# 推荐 Groq（免费、极快）：https://console.groq.com/keys
# STT_BASE_URL=https://api.groq.com/openai/v1
# STT_API_KEY=gsk_your_groq_key
# STT_MODEL=whisper-large-v3
#
# 也可以用本地 Whisper server 或硅基流动（国内）等 OpenAI 兼容服务
# 不设 STT_BASE_URL 时，选"本地 Whisper"会用 Python 脚本 (pip install faster-whisper)
# WHISPER_MODEL=base
# WHISPER_LANGUAGE=
# PYTHON_PATH=python

# 自动记忆（一般不用改，系统会自动选模型）
# AUTO_LEARN_MODEL=
AUTO_LEARN_COOLDOWN=300
